# ===========================================
# Vectium Web - Environment Variables
# ===========================================

# ===========================================
# Farmateca - Firebase (Named App 'farmateca')
# ===========================================
# Get these from Firebase Console → Project Settings → Web App
NEXT_PUBLIC_FARMATECA_FIREBASE_API_KEY=
NEXT_PUBLIC_FARMATECA_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FARMATECA_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FARMATECA_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FARMATECA_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FARMATECA_FIREBASE_APP_ID=

# ===========================================
# Farmateca - Firebase Admin SDK (server-side)
# ===========================================
# JSON completo de la service account (sin saltos de línea).
# Obtener: Firebase Console → Project Settings → Service accounts → Generate new private key
# Copiar el JSON y pegarlo como una sola línea (reemplazar \n literales)
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# ===========================================
# Farmateca - RevenueCat (server-side REST API)
# ===========================================
# Secret key para verificar suscripciones compradas en móvil desde la web.
# Obtener: RevenueCat Dashboard → Project → API Keys → Secret keys
# Formato: sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_SECRET_KEY=

# Reservada — RevenueCat Web SDK (no configurado: requiere Stripe conectado)
NEXT_PUBLIC_FARMATECA_REVENUECAT_WEB_KEY=

# ===========================================
# Farmateca - Flow.cl (pagos web)
# ===========================================
# Obtener: Flow.cl → Mi cuenta → Datos de integración
FLOW_API_KEY=
FLOW_SECRET_KEY=
# Valores: 'production' | 'sandbox'
FLOW_ENV=sandbox

# ===========================================
# EmailJS (formulario de contacto Vectium)
# ===========================================
# Obtener: EmailJS Dashboard → Account / Email Services / Email Templates
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# ===========================================
# App URL (usado en URLs de retorno de Flow)
# ===========================================
NEXT_PUBLIC_APP_URL=https://vectium.cl
